{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["flex&roll_pro/backend/**"]
  },
  "deploy": {
    "startCommand": "cd flex&roll_pro/backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
